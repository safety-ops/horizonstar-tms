{
  "manifest_version": 3,
  "name": "Load Importer - Horizon Star TMS",
  "version": "2.0.0",
  "description": "Import loads from Central Dispatch and Super Dispatch into Horizon Star TMS",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "*://www.centraldispatch.com/*",
    "*://site.centraldispatch.com/*",
    "*://app.centraldispatch.com/*",
    "*://*.centraldispatch.com/*",
    "*://carrier.superdispatch.com/*",
    "https://yrrczhlzulwvdqjwvhtu.supabase.co/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.centraldispatch.com/*",
        "*://site.centraldispatch.com/*",
        "*://app.centraldispatch.com/*",
        "*://*.centraldispatch.com/*",
        "*://carrier.superdispatch.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
